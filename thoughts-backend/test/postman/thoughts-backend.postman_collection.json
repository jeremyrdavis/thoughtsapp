    {
      "name": "Get Thought by ID",
      "item": [
        {
          "name": "GET /thoughts/:id - get existing thought",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
