            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Stay hungry, stay foolish. That is the real lesson.\",\n  \"author\": \"Steve Jobs (updated)\",\n  \"authorBio\": \"Co-founder of Apple Inc.\",\n  \"status\": \"APPROVED\"\n}"
            },
