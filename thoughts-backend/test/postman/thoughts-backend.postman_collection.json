              "mode": "raw",
              "raw": "{\n  \"content\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/thoughts",
              "host": ["{{baseUrl}}"],
              "path": ["thoughts"]
            }
          }
        }
