                  "",
                  "pm.test('Response contains correct id', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.eql(pm.collectionVariables.get('thoughtId'));",
                  "});",
                  "",
                  "pm.test('Response has expected fields', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('content');",
                  "    pm.expect(json).to.have.property('author');",
                  "    pm.expect(json).to.have.property('authorBio');",
                  "    pm.expect(json).to.have.property('status');",
                  "    pm.expect(json).to.have.property('thumbsUp');",
                  "    pm.expect(json).to.have.property('thumbsDown');",
                  "    pm.expect(json).to.have.property('createdAt');",
                  "    pm.expect(json).to.have.property('updatedAt');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
