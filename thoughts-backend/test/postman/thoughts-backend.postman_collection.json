            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Short\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/thoughts",
              "host": ["{{baseUrl}}"],
              "path": ["thoughts"]
