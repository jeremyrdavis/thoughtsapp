{
  "info": {
    "name": "Thoughts Backend API",
    "description": "Tests for ThoughtResource endpoints in the thoughts-backend service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "thoughtId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "List Thoughts",
      "item": [
        {
          "name": "GET /thoughts - list all thoughts (default pagination)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is a JSON array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Default page size returns at most 20 items', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.length).to.be.at.most(20);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/thoughts",
              "host": ["{{baseUrl}}"],
              "path": ["thoughts"]
            }
          }
        },
        {
          "name": "GET /thoughts - list with custom pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is a JSON array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Custom page size returns at most 5 items', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.length).to.be.at.most(5);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/thoughts?page=0&size=5",
              "host": ["{{baseUrl}}"],
              "path": ["thoughts"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "5" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Create Thought",
      "item": [
        {
          "name": "POST /thoughts - create a valid thought",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains thought with id', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json.id).to.be.a('string');",
                  "    pm.collectionVariables.set('thoughtId', json.id);",
                  "});",
                  "",
                  "pm.test('Response contains correct content', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.content).to.eql('The only way to do great work is to love what you do.');",
                  "});",
                  "",
                  "pm.test('Response contains author and authorBio', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.author).to.eql('Steve Jobs');",
                  "    pm.expect(json.authorBio).to.eql('Co-founder of Apple');",
                  "});",
                  "",
                  "pm.test('Thumbs up and down default to 0', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.thumbsUp).to.eql(0);",
                  "    pm.expect(json.thumbsDown).to.eql(0);",
                  "});",
                  "",
                  "pm.test('Timestamps are set', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.createdAt).to.not.be.null;",
                  "    pm.expect(json.updatedAt).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"The only way to do great work is to love what you do.\",\n  \"author\": \"Steve Jobs\",\n  \"authorBio\": \"Co-founder of Apple\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/thoughts",
              "host": ["{{baseUrl}}"],
              "path": ["thoughts"]
            }
          }
        },
        {
          "name": "POST /thoughts - create thought with defaults (no author/bio)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Author defaults to Unknown', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.author).to.eql('Unknown');",
                  "});",
                  "",
                  "pm.test('Author bio defaults to Unknown', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.authorBio).to.eql('Unknown');",
                  "});",
                  "",
                  "pm.test('Status defaults to IN_REVIEW', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('IN_REVIEW');",
                  "});",
                  "",
                  "// Clean up: store id for later deletion",
                  "const json = pm.response.json();",
                  "pm.environment.set('defaultThoughtId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"A default thought with no author or bio provided.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/thoughts",
              "host": ["{{baseUrl}}"],
              "path": ["thoughts"]
            }
          }
        },
        {
          "name": "POST /thoughts - validation error: content too short",
          "event": [
